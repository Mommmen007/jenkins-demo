pipeline {
    agent any

    parameters {
        choice(
            name: 'ENV',
            choices: ['dev', 'stg', 'prod'],
            description: 'Choose Environment'
        )
    }

    stages {

        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }
        stage('Terraform Workspace') {
            steps {
                sh """
                    terraform workspace select ${params.ENV} || terraform workspace new ${params.ENV}
                    terraform workspace list
                """
                }
        }

        stage('Terraform Plan') {
            steps {
                sh "terraform plan -var-file=${params.ENV}.tfvars"
            }
        }

        stage('Approval') {
            steps {
                input message: "Deploy to ${params.ENV} ?", ok: "Apply"
            }
        }

        stage('Terraform Apply') {
            steps {
                sh "terraform apply -auto-approve -var-file=${params.ENV}.tfvars"
            }
        }
    }
    post {

    success {
        emailext(
            to: 'momenpepo11@gmail.com',
            subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body: """
Hello,

Your Jenkins Pipeline completed successfully.

Job Name   : ${env.JOB_NAME}
Build No   : ${env.BUILD_NUMBER}
Environment: ${params.ENV}
Status     : SUCCESS

Build URL:
${env.BUILD_URL}
"""
        )
    }

    failure {
        emailext(
            to: 'momenpepo11@gmail.com',
            subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body: """
Hello,

Your Jenkins Pipeline has failed.

Job Name   : ${env.JOB_NAME}
Build No   : ${env.BUILD_NUMBER}
Environment: ${params.ENV}
Status     : FAILED

Check the logs:
${env.BUILD_URL}
"""
        )
    }

}
}
