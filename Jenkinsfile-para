pipeline {
    agent any

    parameters {
        choice(
            name: 'ENV',
            choices: ['dev', 'stg', 'prod'],
            description: 'Choose Environment'
        )
    }

    stages {

        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }
        stage('Terraform Workspace') {
            steps {
                sh """
                    terraform workspace select ${params.ENV} || terraform workspace new ${params.ENV}
                    terraform workspace list
                """
                }
        }

        stage('Terraform Plan') {
            steps {
                sh "terraform plan -var-file=${params.ENV}.tfvars"
            }
        }

        stage('Approval') {
            steps {
                input message: "Deploy to ${params.ENV} ?", ok: "Apply"
            }
        }

        stage('Terraform Apply') {
            steps {
                sh "terraform apply -auto-approve -var-file=${params.ENV}.tfvars"
            }
        }
    }
}
